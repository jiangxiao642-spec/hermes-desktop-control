#!/usr/bin/env python3
"""SOM 扫描——截图 + vision 标注所有可交互元素，缓存坐标。

用法:
  som-scan              # 截图 → vision → 缓存到 /tmp/som-cache.json
  som-scan --show       # 扫描并显示元素列表
  som-scan --file <path>  # 用已有截图不重新截
"""

import sys
import json
import subprocess
from pathlib import Path

CACHE_PATH = Path("/tmp/som-cache.json")
SCREENSHOT_PATH = "/tmp/som-screenshot.png"

FULLSOM_PROMPT = """Analyze this screenshot and identify ALL interactive UI elements.

For each interactive element (buttons, text inputs, checkboxes, dropdowns, links,
clickable icons, menu items, tabs, sliders, toggle switches), return:

1. A number label [1], [2], [3]...
2. The type of element (Button, Edit/TextInput, CheckBox, ComboBox, Link, Icon, Tab, MenuItem, Slider, Toggle)
3. Its visible text/label (if any, in original language)
4. Approximate pixel coordinates (x, y, width, height) relative to TOP-LEFT of screenshot

Return ONLY the structured list. Only include elements that are currently visible
and appear interactive (not static text, not decoration, not background).

Example format:
  [1] Button "Send" (350, 620, 80x32)
  [2] Edit "Message input" (50, 615, 290x40)
  [3] Tab "Files" (400, 30, 60x30)

Be thorough but don't hallucinate. Only label what you can clearly see as interactive."""


import re

_SOM_LINE_RE = re.compile(
    r'\[(\d+)\]\s+(\w+)\s+"([^"]*)"\s+\((\d+),\s*(\d+),\s*(\d+)x(\d+)\)'
)


def parse_som_response(text: str) -> list[dict]:
    elements = []
    for m in _SOM_LINE_RE.finditer(text):
        elements.append({
            "index": int(m.group(1)),
            "type": m.group(2),
            "label": m.group(3),
            "x": int(m.group(4)),
            "y": int(m.group(5)),
            "w": int(m.group(6)),
            "h": int(m.group(7)),
            "cx": int(m.group(4)) + int(m.group(6)) // 2,
            "cy": int(m.group(5)) + int(m.group(7)) // 2,
        })
    return elements


def main():
    show = "--show" in sys.argv
    use_file = None
    for i, a in enumerate(sys.argv):
        if a == "--file" and i + 1 < len(sys.argv):
            use_file = sys.argv[i + 1]

    # Step 1: Screenshot
    if use_file:
        img_path = use_file
    else:
        result = subprocess.run(
            ["desktop-shot", SCREENSHOT_PATH], capture_output=True, text=True
        )
        if result.returncode != 0:
            print(f"[som-scan] ❌ 截图失败: {result.stderr}", file=sys.stderr)
            sys.exit(1)
        img_path = SCREENSHOT_PATH

    # Step 2: Vision SOM
    result = subprocess.run(
        ["vision-relay", img_path, FULLSOM_PROMPT],
        capture_output=True, text=True, timeout=120
    )
    if result.returncode != 0:
        print(f"[som-scan] ❌ vision 失败: {result.stderr}", file=sys.stderr)
        sys.exit(1)

    # Step 3: Parse
    elements = parse_som_response(result.stdout)
    if not elements:
        print("[som-scan] ⚠️ 未识别到可交互元素", file=sys.stderr)
        print(f"[som-scan] vision 原始输出:\n{result.stdout[:500]}", file=sys.stderr)
        sys.exit(1)

    # Step 4: Save cache
    cache = {
        "screenshot": img_path,
        "count": len(elements),
        "elements": elements,
    }
    CACHE_PATH.write_text(json.dumps(cache, ensure_ascii=False, indent=2))

    # Step 5: Display
    if show or "--show" in sys.argv:
        print(f"🔍 {len(elements)} 个可交互元素:\n")
        for el in elements:
            print(f"  [{el['index']:>2}] {el['type']:<10} \"{el['label']}\"  "
                  f"({el['x']},{el['y']},{el['w']}x{el['h']})  → 中心({el['cx']},{el['cy']})")
        print(f"\n📁 缓存: {CACHE_PATH}")

    print(f"[som-scan] ✅ {len(elements)} 个元素 → {CACHE_PATH}")


if __name__ == "__main__":
    main()
